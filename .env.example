# Required Telegram settings.
TG_BOT_TOKEN=123456:replace_with_your_bot_token
TG_ALLOWED_CHAT_ID=464100862

# Required CMS settings.
CMS_BASE_URL=http://192.168.1.10:9527
CMS_USERNAME=your_cms_username
CMS_PASSWORD=replace_with_your_cms_password

# Runtime storage.
DB_PATH=/data/submissions.db
TG_POLL_TIMEOUT=30
HTTP_TIMEOUT=60
STATUS_POLL_SECONDS=300
STATUS_POLL_INTERVAL=20
LOG_LEVEL=INFO

# Workflow mode:
# - direct: submit original share link to CMS and let CMS handle its normal flow.
# - self_share_sync: transfer, wait for CMS organize, create your own permanent 115 share, run CMS share-sync, move share STRM, then optionally delete the transferred 115 source after confirmation.
WORKFLOW_MODE=self_share_sync

# 115 self-share workflow.
P115_COOKIE_PATH=/config/115-cookies.txt
# 115 API 最小请求间隔；账号被风控后建议调大到 3-5。
P115_MIN_REQUEST_INTERVAL_SECONDS=2
SELF_SHARE_RECEIVE_CID=
SELF_SHARE_STRM_ROOT=/mnt/user/Unraid/strm/share
SELF_SHARE_CMS_LOCAL_PATH=/media/share
SELF_SHARE_CMS_CID=0
# Historical env name.
# With TASK_ENGINE_ENABLED=true, Task engine path deletes the 115 source immediately after your own permanent share is created.
# With TASK_ENGINE_ENABLED=false, the legacy SubmissionStore path keeps compatibility behavior and is not the same safety guarantee.
SELF_SHARE_CLEANUP_AFTER_EMBY=true
# Optional: comma-separated 115 parent CIDs to clean matching receive-stage residues from.
SELF_SHARE_SOURCE_CLEANUP_PARENT_IDS=
SELF_SHARE_AUTO_ORGANIZE_RETRY_SECONDS=15

# Optional: map your CMS organized 115 parent folder CIDs to categories.
# Format: parent_cid=category,parent_cid=category
# Leave blank to disable parent-CID category inference, or set this for your own CMS folder IDs.
CMS_PARENT_CID_CATEGORY_MAP=

# STRM move settings.
STRM_SOURCE_ROOTS=/mnt/user/Unraid/strm/share,/mnt/user/Unraid/strm/转存
MOVE_CONFLICT_POLICY=merge
STRM_STABLE_SECONDS=30
# Format: category=absolute_path,category=absolute_path
STRM_LIBRARY_MAP=华语电影=/mnt/user/Unraid/strm/转存/Movie/电影/华语电影,欧美电影=/mnt/user/Unraid/strm/转存/Movie/电影/欧美电影,亚洲电影=/mnt/user/Unraid/strm/转存/Movie/电影/亚洲电影,动漫电影=/mnt/user/Unraid/strm/转存/Movie/电影/动漫电影,国产电视=/mnt/user/Unraid/strm/转存/TVCN,外国电视=/mnt/user/Unraid/strm/转存/TV,番剧=/mnt/user/Unraid/strm/转存/Dongman

# Emby confirmation.
EMBY_BASE_URL=http://192.168.1.10:8096
EMBY_API_KEY=replace_with_your_emby_api_key
EMBY_USER_ID=

# Optional OpenAI-compatible fallback classification.
OPENAI_CLASSIFY_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_only_if_enabled
OPENAI_MODEL=gpt-4.1-mini
OPENAI_HIGH_CONFIDENCE=0.75
OPENAI_SUGGEST_CONFIDENCE=0.45

# v0.2 authoritative task engine and Web admin.
# Set TASK_ENGINE_ENABLED=false to roll back to the legacy SubmissionStore + polling path.
TASK_ENGINE_ENABLED=true
TASK_DB_PATH=/data/tasks.db
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8787
WEB_TOKEN=
TASK_WORKER_INTERVAL_SECONDS=5
TASK_MAX_RETRIES=3

# Background repair for stuck records.
STATUS_REPAIR_ENABLED=true
STATUS_REPAIR_INTERVAL_SECONDS=300
STATUS_REPAIR_LIMIT=50
